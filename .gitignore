# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.js
.pnpm/
.npm/
.go/
.direnv/

# testing
coverage/
**/__screenshots__/**

# production
.output
.vinxi
dist/
build/
/better-ao
**/public/storybook/
storybook-static

# Embedded dashboard mirror (copied from web/dist/client/ by
# scripts/copy-dashboard.mjs before `go build`). Only the .gitkeep is
# committed; everything else is build output.
cmd/better-ao/dashboard/*
!cmd/better-ao/dashboard/.gitkeep

# misc
.DS_Store
*.pem
.idea/
.eslintcache
.db
tsconfig.tsbuildinfo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# Build info
build-info.gen.json

# Prisma
prisma/dev.db
prisma/dev.db-journal
src/server/db/generated

# Emails
.react-email

# playwright
test-results/
playwright-report/
playwright/.cache/
**/e2e/.auth

certificates

*storybook.log
app.config.timestamp_*.js
.tanstack
.vite/
.nitro

# vscode
/.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.example.json

# zed
/.zed/*
!/.zed/settings.example.json

# local agent / CLI session artifacts (not project config)
.entire/
.antigravitycli/
.playwright-cli/
